<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.MyApplication" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_default</item>
        <item name="colorPrimaryVariant">@color/accent_default</item>
        <item name="colorOnPrimary">@color/bg_dark_base</item>

        <item name="colorSecondary">@color/accent_default</item>
        <item name="colorSecondaryVariant">@color/accent_default</item>
        <item name="colorOnSecondary">@color/bg_dark_base</item>

        <item name="android:windowBackground">@color/bg_dark_base</item>
        <item name="android:colorBackground">@color/bg_dark_base</item>
        <item name="colorSurface">@color/bg_dark_surface</item>

        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>

        <item name="android:statusBarColor">@color/bg_dark_base</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>

        <item name="android:navigationBarColor">@color/bg_dark_surface</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>
    </style>
</resources>