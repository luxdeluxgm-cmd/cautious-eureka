<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ll_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_rounded"
    android:padding="0dp">

    <LinearLayout
        android:id="@+id/ll_widget_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_dark_surface_elevated" android:padding="12dp"
        android:gravity="center">

        <TextView
            android:id="@+id/tv_widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚔️ Zadania RPG"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:textSize="16sp"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/stroke_color"/>

    <ListView
        android:id="@+id/widget_list_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:divider="@color/stroke_color" android:dividerHeight="1dp"
        android:layout_marginTop="0dp"/>

    <TextView
        android:id="@+id/appwidget_empty_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="Brak zadań na dziś!"
        android:visibility="gone"
        android:textColor="@color/text_secondary"
        android:textStyle="italic"/>
</LinearLayout>